{
  "name": "rslib-island",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "rslib build && storybook build && cp -r storybook-static/* dist",
    "dev": "concurrently 'bun rslib mf-dev' 'bun storybook'",
    "dev2": "rslib build --watch",
    "lint": "eslint .",
    "build:storybook": "storybook build -o dist",
    "storybook": "storybook dev"
  },
  "dependencies": {
    "@github-ui/storybook-addon-performance-panel": "^1.0.1",
    "storybook-addon-rslib": "^3.2.3",
    "@module-federation/rsbuild-plugin": "^2.0.1",
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@module-federation/storybook-addon": "^6.0.1",
    "@rsbuild/core": "~1.7.3",
    "@rsbuild/plugin-react": "^1.4.5",
    "@rslib/core": "^0.19.6",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-links": "^10.2.10",
    "@storybook/addon-onboarding": "^10.2.10",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^10.2.10",
    "storybook-react-rsbuild": "^3.2.3",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "eslint-plugin-storybook": "10.2.10"
  }
}
