{
  "name": "rslib-island",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "rslib build && storybook build && cp -r storybook-static/* dist",
    "dev": "concurrently 'pnpm rslib mf-dev' 'pnpm storybook dev'",
    "dev2": "rslib build --watch",
    "lint": "eslint .",
    "build:storybook": "storybook build -o dist",
    "storybook": "storybook dev"
  },
  "dependencies": {
    "@module-federation/rsbuild-plugin": "^0.22.0",
    "express": "^5.2.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@module-federation/storybook-addon": "^5.0.2",
    "@rsbuild/core": "~1.7.2",
    "@rsbuild/plugin-react": "^1.4.2",
    "@rslib/core": "^0.19.1",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-links": "^10.1.11",
    "@storybook/addon-onboarding": "^10.1.11",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.7",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "prettier": "3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^10.1.11",
    "storybook-addon-rslib": "^3.2.0",
    "storybook-react-rsbuild": "^3.2.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "eslint-plugin-storybook": "10.1.11"
  }
}
