{
  "name": "rslib-island",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "rslib build && storybook build && mv storybook-static/* dist",
    "dev": "concurrently 'pnpm rslib mf-dev' 'pnpm storybook dev'",
    "dev2": "rslib build --watch",
    "lint": "eslint .",
    "build:storybook": "storybook build -o dist",
    "storybook": "storybook dev"
  },
  "dependencies": {
    "@module-federation/rsbuild-plugin": "^0.20.0",
    "express": "^5.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@module-federation/storybook-addon": "^4.0.33",
    "@rsbuild/core": "~1.5.17",
    "@rsbuild/plugin-react": "^1.4.1",
    "@rslib/core": "^0.15.0",
    "@storybook/addon-docs": "^9.1.13",
    "@storybook/addon-essentials": "^9.0.0-alpha.12",
    "@storybook/addon-links": "^9.1.13",
    "@storybook/addon-onboarding": "^9.1.13",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/express": "^5.0.3",
    "@types/react": "^19.2.2",
    "eslint": "^9.37.0",
    "globals": "^16.4.0",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "storybook": "^9.1.13",
    "storybook-addon-rslib": "^2.1.2",
    "storybook-react-rsbuild": "^2.1.2",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "eslint-plugin-storybook": "9.1.13"
  }
}